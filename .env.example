VITE_APP_BASE=/qc-web/
VITE_API_BASE=/qc-web-api/api

# ── Tutti RDS (PostgreSQL) for spec data sync ──────────────────
# Required for syncing bead spec data to centralized RDS
TUTTI_RDS_HOST=your-rds-host.region.rds.amazonaws.com
TUTTI_RDS_PORT=5432
TUTTI_RDS_DATABASE=your_database_name
TUTTI_RDS_USER=your_rds_user
TUTTI_RDS_PASSWORD=your_rds_password
# Schema name for spec tables (default: QC_spec)
TUTTI_RDS_SPEC_SCHEMA=QC_spec
